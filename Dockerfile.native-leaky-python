FROM python:3.12-slim

RUN apt-get update && apt-get install -y curl && rm -rf /var/lib/apt/lists/*

WORKDIR /app

ENV DD_SERVICE="native-leaky-api-python"
ENV DD_ENV="prod"
LABEL com.datadoghq.tags.service="native-leaky-api-python"
LABEL com.datadoghq.tags.env="prod"

COPY src/python/requirements.txt /app/
RUN pip install --no-cache-dir -r requirements.txt

COPY src/python/native_leaky_server.py /app/

EXPOSE 9088

CMD ["ddtrace-run", "python", "native_leaky_server.py"]
